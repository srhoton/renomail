<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Sample Subscriptions</title>
  </head>
  <body>
    <outline text="Top Feed" title="Top Feed" type="rss"
             xmlUrl="https://example.com/top.xml" htmlUrl="https://example.com/"/>
    <outline text="News" title="News">
      <outline text="Nested Feed" title="Nested Feed" type="rss"
               xmlUrl="https://example.com/nested.xml" htmlUrl="https://example.com/nested"/>
    </outline>
  </body>
</opml>
